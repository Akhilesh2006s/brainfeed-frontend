# API base URL (see also .env.development).
#
# Development with Vite proxy (recommended):
#   - In .env.development set VITE_API_URL= (empty) so requests go to same origin `/api/...`
#     and vite.config.ts proxies to http://localhost:3001
#   - Start backend: cd backend && node index.cjs
#
# Development calling the API directly (CORS must allow your dev origin):
#   VITE_API_URL=http://localhost:3001
#
# Production build (`npm run build`):
#   Prefer `frontend/.env.production` (committed) or set the same var on Vercel/Netlify.
#
# Deployed backend (Railway) — default in this repo:
VITE_API_URL=https://brainfeed-backend-production-ab6d.up.railway.app
#
# Local backend:
# VITE_API_URL=http://localhost:3001
