# Used when you run `npm run dev`. Restart Vite after changing.
#
# LOCAL (default): leave empty — the app calls `/api/...` and Vite proxies to
# http://localhost:3001 (see vite.config.ts). Start backend: `cd backend && npm start`
VITE_API_URL=

# RAILWAY: comment out the line above and uncomment this to hit the deployed API
# (browser calls Railway directly; CORS must allow http://localhost:5173 on the server).
# VITE_API_URL=https://brainfeed-backend-production-ab6d.up.railway.app
