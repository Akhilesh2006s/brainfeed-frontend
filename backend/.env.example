PORT=3001
NODE_ENV=production
HOST=0.0.0.0

# Optional: frontend URL(s) for CORS (comma-separated).
# On Railway set e.g.: CORS_ORIGIN=https://your-frontend.vercel.app,http://localhost:5173
# CORS_ORIGIN=

CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

MONGO_URI=mongodb+srv://your_user:your_password@cluster0.xxxxx.mongodb.net/your_database?appName=Cluster0

JWT_SECRET=your_jwt_secret

# Admin credentials (first login with these creates the admin in MongoDB)
ADMIN_EMAIL=admin@brainfeed.com
ADMIN_PASSWORD=12345678
